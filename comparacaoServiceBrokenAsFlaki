const axios = require('axios');
const moment = require('moment');
async function getComparacao(symbol, tam, cont = 0) {
const url = 'https://www.alphavantage.co/query';
if (cont > 3) return;
console.log(`[Tentativa ${cont}] Chamando API para: ${symbol}...`);
return axios.get(url, {
params: {
function: 'TIME_SERIES_DAILY',
symbol: symbol,
apikey: process.env.ALPHA_VANTAGE_KEY
}
}).then(res => {
const data = res.data;
const timeSeries = data["Time Series (Daily)"];
const recebidos = timeSeries ? Object.keys(timeSeries).length : 0;

if (timeSeries && Object.keys(timeSeries).length >= tam) {
console.log("Sucesso");
console.log(`Esperava ${tam} ou mais, recebi ${recebidos}.`);
if(cont < 3){
    return getComparacao(symbol, tam, cont + 1);
}
} else {
console.warn(`[BUG REPRODUZIDO] Esperava ${tam} ou mais, mas recebi ${recebidos}.`);
throw new Error(`Inconsistência da API detectada: Recebi apenas ${recebidos}`);
}
}).catch(err => {
console.warn(`[${err}]`);
return (`${err}`);
});
}
module.exports = { getComparacao };

                                                                                                               





                                                                          